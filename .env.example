### Example environment variables for Smart Organ Donation System
# Copy to .env and update values

SECRET_KEY=replace_me_with_a_secure_random_value
FODS_SECRET_KEY=replace_me_with_a_secure_random_value
DATABASE_URL=sqlite:///organ_donation.db

# Twilio (replace with your own credentials)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE=+1XXXXXXXXXX

# Admin credentials (change immediately in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@aaa
